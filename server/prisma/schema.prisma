// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum RoleType {
  ADMIN
  OWNER
  BUILDER
  USER
}

enum ListingStatus {
  FOR_SALE
  FOR_RENT
  SOLD
  PENDING
  OFF_PLAN
}

enum PropertyCategory {
  RESIDENTIAL
  COMMERCIAL
  LUXURY
  VACATION
  INDUSTRIAL
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String     // Hashed password
  name          String?
  avatar        String?
  role          RoleType   @default(USER)
  
  // Role-Specific Information
  phone         String?
  businessName  String?    // For Owners & Builders
  address       String?    // For Owners
  licenseNumber String?    // For Builders
  website       String?    // For Builders
  experience    String?    // For Builders
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  // Relations
  properties    Property[] @relation("PropertyOwner")
  projects      Project[]  @relation("BuilderProject")
}

model Property {
  id                String           @id @default(cuid())
  title             String
  slug              String           @unique
  category          PropertyCategory @default(RESIDENTIAL)
  status            ListingStatus    @default(FOR_SALE)
  
  // Financials
  price             Float
  currency          String           @default("USD")
  pricePerSqft      Float?
  priceHistory      String?           // JSON string
  estimatedROI      Float?           // Annual percentage
  rentalYield       Float?           // Monthly estimated income

  // Physical Specifications
  bedrooms          Int?
  bathrooms         Int?
  totalArea         Float?           // In Sqft
  lotSize           Float?           // In Acres/Sqft
  floors            Int?             @default(1)
  parkingSpaces     Int?             @default(0)
  yearBuilt         Int?
  handoverDate      DateTime?        // For off-plan
  constructionProgress Int?          @default(0) // 0-100
  constructionPhase String?          // e.g., "Foundation", "Finishing"

  // Location & Connectivity
  address           String
  city              String
  neighborhood      String?
  latitude          Float?
  longitude         Float?
  viewType          String?          // e.g., "Sea View", "Skyline"
  noiseLevel        String?          // "Low", "Medium", "High"
  airQualityIndex   Int?
  connectivityScore String?           // JSON string
  sunOrientation    String?          // "North", "South", etc.

  // Amenities & Sustainability
  internalAmenities String?           // Comma separated
  externalAmenities String?           // Comma separated
  communityAmenities String?          // Comma separated
  energyRating      String?          // "A" through "G"
  greenTech         String?           // Comma separated

  // Media
  primaryImage      String
  imageGallery      String?           // Comma separated
  videoUrl          String?
  virtualTourUrl    String?
  floorPlans        String?           // Comma separated
  brochureUrl       String?

  // Sale Specifics
  serviceCharges    Float?            // Annual HOA/Service fees
  ownershipType     String?           // Freehold, Leasehold
  paymentPlan       String?           // JSON/String description
  propertyTax       Float?            // Annual estimate
  mortgageEstimate  Float?            // Monthly starting payment

  // Rent Specifics
  rentFrequency     String?           // Monthly, Quarterly, Yearly
  securityDeposit   Float?            
  furnishingStatus  String?           // Furnished, Unfurnished, etc.
  utilitiesIncluded Boolean           @default(false)
  petPolicy         String?           
  minLeaseTerm      String?           

  // Deep Information
  roomBreakdown     String?           // JSON string of dimensions
  neighborhoodSafety Float?           // 1-10 score
  nearbySchools     String?           // JSON/String of schools/distances

  // Trust & Analytics
  isVerified        Boolean          @default(false)
  rating            Float            @default(4.5)
  reviewsCount      Int              @default(10)
  titleDeedRef      String?
  tags              String?           // Comma separated
  viewCount         Int              @default(0)
  saveCount         Int              @default(0)

  // Ownership & Timestamps
  ownerId           String
  owner             User             @relation("PropertyOwner", fields: [ownerId], references: [id])
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  builderId   String
  builder     User     @relation("BuilderProject", fields: [builderId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
